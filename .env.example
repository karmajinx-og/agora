# Copy to ".env" in this folder (web/) and fill in. ".env" is gitignored — never commit secrets.
#
# 1) Create an API token (read-only for Pages inspection):
#    https://dash.cloudflare.com/profile/api-tokens  → Create Token → Create Custom Token
#
# 2) Permissions (minimal for list/read Pages + wrangler whoami):
#    - Account → Cloudflare Pages → Read
#    - User → Memberships → Read   (lets Wrangler resolve your account)
#    Optional: User → User Details → Read (silences “unable to retrieve email” in wrangler whoami)
#
#    Optional if you also want DNS/zone read for a domain:
#    - Zone → Zone → Read
#    - Zone → DNS → Read
#
# 3) Account Resources: include your account (or “All accounts” for a personal token).
#
# 4) Save the token once; Cloudflare shows it only at creation time.

CLOUDFLARE_API_TOKEN=

# Optional — paste from Cloudflare dashboard right sidebar on any zone/account overview.
# Some Wrangler commands work better with it set explicitly.
CLOUDFLARE_ACCOUNT_ID=
